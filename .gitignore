# ------------------------------
# System files and metadata
# ------------------------------

# macOS Finder metadata
.DS_Store
**/.DS_Store

# ------------------------------
# FreeCAD
# ------------------------------

# Auto-backup and auto-save files
*.FCBak
*.FCStd1
*.FCStd2
*.FCStd3
*.FCStd4
*.FCStd5

# ------------------------------
# KiCAD
# ------------------------------
# Generated files and build artifacts
*.kicad_pcb.zip

# Lock files and local runtime caches
*.kicad_pcb.lck
*.kicad_sch.lck
fp-info-cache

# Local project preferences (machine/user specific)
*.kicad_prl
*.kicad_prl-bak
*.kicad_pro-bak

# Auto-generated backup folders
*-backups/

# KiCAD temporary and recovery artifacts
*.kicad_sch-bak
*.kicad_pcb-bak
_autosave-*.kicad_sch
_autosave-*.kicad_pcb

# Hash-wrapped autosave/temp artifacts
# Example: #auto_saved_files#
# Also catches editor-style temp files like #filename#
# and swap-like files such as .#filename
#auto_saved_files#
\#*#
.#*
